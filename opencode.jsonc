{
    "$schema": "https://opencode.ai/config.json",
    "provider": {
        "alfagen": {
            "npm": "@ai-sdk/openai-compatible",
            "name": "Alfagen",
            "options": {
                "baseURL": "{file:.secrets/base_url}",
                "apiKey": "{file:.secrets/api_key}"
            },
            "models": {
                "Qwen/Qwen3.6-35B-A3B-FP8": {
                    "name": "Qwen/Qwen3.6-35B-A3B-FP8"
                },
                "deepseek-ai/DeepSeek-V4-Flash": {
                    "name": "deepseek-ai/DeepSeek-V4-Flash"
                },
                "zai-org/GLM-5.2-FP8": {
                    "name": "zai-org/GLM-5.2-FP8"
                },
                "deepseek-ai/DeepSeek-V4-Pro": {
                    "name": "deepseek-ai/DeepSeek-V4-Pro"
                }
            }
        }
    },
    "model": "zai-org/GLM-5.2-FP8",
    "agents": {
        "plan": {
            "model": "deepseek-ai/DeepSeek-V4-Flash"
        },
        "build": {
            "model": "zai-org/GLM-5.2-FP8"
        }
    },
    "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "task": "allow",
        "skill": "allow",
        "lsp": "allow",
        "question": "allow",
        "external_directory": "allow",
        "doom_loop": "allow",
        "bash": {
            "*": "allow",

            "rm *": "ask",
            "rmdir *": "ask",

            "git reset --hard *": "ask",
            "git clean *": "ask",
            "git push *": "ask",
            "git commit *": "ask",

            "pip install *": "ask",
            "uv add *": "ask",
            "npm install *": "ask",

            "docker system prune *": "ask"
        }
    },
    "share": "disabled",
    "formatter": true,
    "theme": "everforest"
}
